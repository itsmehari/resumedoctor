# ===========================================
# ResumeDoctor – Local Development Environment (resumedoctor.in)
# Copy to .env.local and fill in values
# ===========================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL) – use Supabase/Neon for hosted; DIRECT_URL required for Neon migrations
DATABASE_URL="postgresql://postgres:dev@localhost:5432/resumedoctor_dev"
# DIRECT_URL="postgresql://..." # For Neon: direct (non-pooled) connection for migrations

# Auth (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Master admin (optional): comma-separated emails allowed to access /admin when role is admin.
# If unset, any user with role "admin" may access (legacy). Production: set to your owner email(s).
# MASTER_ADMIN_EMAILS=you@example.com
# Super admin only (optional): comma-separated subset allowed for exports, impersonation,
# user PATCH, promos mutations, trial approve/reject, job PATCH, revoke-sessions.
# If unset, all master admins have those powers.
# SUPER_ADMIN_EMAILS=owner@example.com
# REQUIRE_ADMIN_2FA=true
# ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.2
# One-off CLI: promote user to admin (requires DATABASE_URL; do not commit PROMOTE_ADMIN_EMAIL)
# PROMOTE_ADMIN_EMAIL=you@example.com
# Trial session JWT (optional locally; falls back to NEXTAUTH_SECRET). Production requires NEXTAUTH_SECRET or TRIAL_SESSION_SECRET.
# TRIAL_SESSION_SECRET=generate-with-openssl-rand-base64-32

# OAuth (optional – set NEXT_PUBLIC_*_ENABLED=true to show buttons)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_ENABLED=true
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# NEXT_PUBLIC_LINKEDIN_ENABLED=true

# AI – Groq (free, recommended) or OpenAI (fallback)
GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# Redis (optional for MVP)
# REDIS_URL=redis://localhost:6379

# Email (ZeptoMail / Zoho) – transactional REST API for verification, trial OTP, password reset
# Send Mail token: ZeptoMail → your Agent → SMTP/API → API tab → Send Mail Token (copy full token)
# Associate + verify domain resumedoctor.in under Agents before sending from @resumedoctor.in
# Test locally: npm run test:email (requires ZEPTOMAIL_SEND_TOKEN + EMAIL_FROM)
ZEPTOMAIL_SEND_TOKEN=
# If sends fail with 401, try India API host (matches dashboard “Host: api.zeptomail.in”):
# ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
# Aliases also accepted: ZEPTOMAIL_TOKEN or ZEPTOMAIL_API_KEY
# Required: sender on verified domain in ZeptoMail, e.g.
EMAIL_FROM="ResumeDoctor <noreply@resumedoctor.in>"
# Optional — defaults to support@resumedoctor.in in code if unset
# EMAIL_REPLY_TO=support@resumedoctor.in

# UPI / QR checkout (India)
# Add images to /public: checkout-qr.png, checkout-trial-qr.png
# Optional: UPI ID for copy button (e.g. yourname@upi)
# NEXT_PUBLIC_UPI_ID=
# - checkout-qr.png … Pro plan (₹199/mo or ₹1499/yr)
# - checkout-trial-qr.png … 14-day trial for ₹1

# SuperProfile — published customer checkout (Share / View link), shape: https://superprofile.bio/vp/<24hex>
# Do not use /create-payment-page/... (seller editor). If env is wrong, the app rewrites editor URLs to /vp/<id> when possible.
# NEXT_PUBLIC_SUPERPROFILE_URL_PRO_MONTHLY=https://superprofile.bio/vp/69db33e8da78960013e814b3
# NEXT_PUBLIC_SUPERPROFILE_URL_PRO_ANNUAL=https://superprofile.bio/vp/69dca13af2e2e30013365462
# NEXT_PUBLIC_SUPERPROFILE_URL_TRIAL_14=https://superprofile.bio/vp/69e5cabddd64680013de4395
# NEXT_PUBLIC_SUPERPROFILE_URL_RESUME_PACK=https://superprofile.bio/vp/69e5caf05275a70013fc8928
# Pro Link – standalone ₹99/mo add-on (custom URL, view analytics, footer removal).
# Free for pro_annual subscribers; required as a separate purchase for monthly Pro and Basic.
# NEXT_PUBLIC_SUPERPROFILE_URL_PRO_LINK=https://superprofile.bio/vp/<24hex>
# Webhook POST https://www.resumedoctor.in/api/webhooks/superprofile (prod — use www; apex redirects 308)
# JSON: idempotencyKey, email, productKey, optional credits — see docs/DEPLOYMENT-REQUIREMENTS.md
# SUPERPROFILE_WEBHOOK_SECRET=long-random-use-openssl-rand-hex-32
# Send Authorization: Bearer <secret> or X-Superprofile-Webhook-Secret: <secret>

# Analytics & Ads (optional – consent-gated)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
# NEXT_PUBLIC_CLARITY_PROJECT_ID=  (Microsoft Clarity – session replay, heatmaps; default: vw2ci97dos)

# File Storage (S3-compatible, for production)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Avatar upload (Vercel Blob – set for file avatar upload in settings)
# VERCEL_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Sentry error tracking (WBS 13.6)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxx@oXXXXXX.ingest.sentry.io/XXXXXX
# SENTRY_DSN=https://xxxxxx@oXXXXXX.ingest.sentry.io/XXXXXX
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=resumedoctor
# SENTRY_AUTH_TOKEN=sntrys_...  (for source map uploads in CI)

# App version for health check
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Database backup (for GitHub Actions db-backup.yml)
# DB_PASSWORD=...
# BACKUP_S3_BUCKET=resumedoctor-backups
