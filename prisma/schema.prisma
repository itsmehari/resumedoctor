// Zesty – Prisma Schema
// WBS 1.3, 2, 3.1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?   // for credentials provider
  role          String    @default("user") // user | admin
  subscription  String    @default("free") // free | trial | pro_monthly | pro_annual | pro_trial_14
  subscriptionId String?
  subscriptionExpiresAt DateTime? // for pro_trial_14 (14-day ₹1 trial)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Email change flow
  pendingEmail         String?
  pendingEmailToken    String?
  pendingEmailTokenExpires DateTime?
  // Notification preferences (JSON: { marketing?, productUpdates? })
  notificationPrefs    Json?
  // 2FA
  twoFactorEnabled     Boolean  @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String?  // JSON array of backup codes

  accounts    Account[]
  sessions    Session[]
  resumes     Resume[]
  exportLogs  ExportLog[]
  coverLetters CoverLetter[]
  coverLetterTemplates CoverLetterTemplate[]
  twoFactorTokens TwoFactorToken[]
  invoices        Invoice[]
  aiUsageLogs     AiUsageLog[]
  featureUsageLogs FeatureUsageLog[]
  jobApplications  JobApplication[]
  // WBS 10.7 – One-time Resume Pack (5 PDF exports for ₹99)
  resumePackCredits Int @default(0)
}

// WBS 10.6 – 14-day trial activation requests (user pays ₹1, submits UPI ref)
model TrialActivationRequest {
  id        String   @id @default(cuid())
  email     String
  upiRef    String   // UPI transaction reference
  status    String   @default("pending") // pending | approved | rejected
  userId    String?  // set when approved
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([status])
}

model PromoCode {
  id           String    @id @default(cuid())
  code         String    @unique
  discountType String    // percent | fixed
  discountValue Int      // e.g. 20 for 20%, or 100 for ₹100
  expiresAt    DateTime?
  usageLimit   Int?
  usageCount   Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([code])
  @@index([expiresAt])
}

model Invoice {
  id        String   @id @default(cuid())
  userId    String
  amount    Int      // in paise or cents
  currency  String   @default("INR")
  plan      String
  status    String   @default("paid") // paid | pending | refunded
  pdfUrl    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// Free Trial – OTP & session (FREE-TRIAL-WORKFLOW-PLAN)
model TrialSession {
  id               String    @id @default(cuid())
  email            String
  otpHash          String
  otpExpiresAt     DateTime
  verifiedAt       DateTime?
  sessionExpiresAt DateTime?
  resumeId         String?
  createdAt        DateTime  @default(now())

  @@index([email])
  @@index([sessionExpiresAt])
}

// 2FA – temporary token for login (userId + TOTP pending)
model TwoFactorToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expires])
}

model OtpAttempt {
  id         String   @id @default(cuid())
  email      String
  type       String   // "send" | "verify"
  success    Boolean
  createdAt  DateTime @default(now())

  @@index([email, createdAt])
}

// Resume & Sections (WBS 3.1)
model Resume {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("Untitled Resume")
  templateId  String   @default("professional-v1")
  content     Json     // sections, blocks - flexible structure
  version     Int      @default(1)
  publicSlug  String?  @unique // Phase 1.3 – shareable link e.g. /r/abc123
  importSource String? // Phase 1.1 – "pdf" | "docx" | null
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     ResumeVersion[]
  exportLogs   ExportLog[]
  coverLetters CoverLetter[]
  atsScores    AtsScoreCache[]
}

model ResumeVersion {
  id        String   @id @default(cuid())
  resumeId  String
  version   Int
  content   Json
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, version])
  @@index([resumeId])
}

// WBS 5.7 – Export history for analytics
model ExportLog {
  id        String   @id @default(cuid())
  userId    String
  resumeId  String
  format    String   // txt | pdf | docx
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
  @@index([createdAt])
}

// WBS 8.1 – Cover letter (linked to resume)
model CoverLetter {
  id         String   @id @default(cuid())
  userId     String
  resumeId   String?  // optional link to resume
  title      String   @default("Untitled Cover Letter")
  company    String?
  role       String?
  content    String   @default("")
  templateId String  @default("professional") // professional | minimal | modern | classic | bold | compact
  tone       String   @default("formal")    // formal | casual | technical
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resumeId])
}

// User's saved cover letter templates (personal)
model CoverLetterTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String   // e.g. "My default", "Tech startup"
  content   String   @default("")
  templateId String  @default("professional")
  tone      String   @default("formal")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// WBS 6.7 – AI usage log for rate limiting (Free: 5/day, Pro: 50/day)
model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // improve-bullet | improve-summary | suggest-bullets | customize-cover
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// WBS 6.6 – AI response cache (hash-keyed, 24h TTL)
model AiResponseCache {
  id        String   @id @default(cuid())
  hash      String   @unique // SHA256 of action+input
  action    String
  response  Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([hash])
  @@index([expiresAt])
}

// WBS 11.5 – Feature usage log (AI calls, ATS runs, exports, cover letters)
model FeatureUsageLog {
  id        String   @id @default(cuid())
  userId    String
  feature   String   // ai | ats | export | cover_letter
  meta      Json?    // e.g. { action: "improve-bullet", format: "pdf" }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
}

// WBS 9.1 – Job listing
model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String?
  industry    String?
  description String
  skills      Json     @default("[]") // string[]
  salaryMin   Int?
  salaryMax   Int?
  currency    String   @default("INR")
  url         String?
  source      String   @default("manual")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications JobApplication[]

  @@index([industry])
  @@index([location])
  @@index([active, createdAt])
}

// WBS 9.6 – Job application tracking per user
model JobApplication {
  id        String    @id @default(cuid())
  userId    String
  jobId     String
  status    String    @default("saved") // saved | applied | interviewing | rejected | offer
  notes     String?
  appliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

// WBS 7.8 – ATS score cache per resume version
model AtsScoreCache {
  id          String   @id @default(cuid())
  resumeId    String
  version     Int
  score       Int      // 0-100
  suggestions Json     // [{ type, message, section? }]
  checks      Json?    // [{ name, pass, detail? }]
  createdAt   DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, version])
  @@index([resumeId])
}

// Security – IP-based rate limiting for unauthenticated payment/account endpoints
model IpRateLimit {
  id        String   @id @default(cuid())
  key       String   @unique  // "{endpoint}:{ip}"
  count     Int      @default(1)
  windowEnd DateTime

  @@index([key])
  @@index([windowEnd])
}

// Security – Audit log for critical destructive/financial operations
model SecurityAuditLog {
  id        String   @id @default(cuid())
  action    String   // "delete_account" | "trial_activation" | "promo_attempt" | "promo_used"
  userId    String?
  ip        String?
  meta      Json?    // extra context (email, promoCode, etc.)
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([userId, createdAt])
}
